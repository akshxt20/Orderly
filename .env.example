# Root environment for docker-compose. Copy to .env and adjust as needed.
# docker-compose reads this file automatically.

# --- Postgres ---
POSTGRES_USER=orderly
POSTGRES_PASSWORD=orderly
POSTGRES_DB=orderly

# --- Backend ---
# Origins allowed to call the API (comma-separated). Add your Netlify URL in prod.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SQL_ECHO=false
