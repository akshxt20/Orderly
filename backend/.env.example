# Copy to .env and fill in. Never commit the real .env.

# Postgres connection string. In docker-compose the host is the service name "db".
# Local (outside docker) example:  postgresql+psycopg2://orderly:orderly@localhost:5432/orderly
DATABASE_URL=postgresql+psycopg2://orderly:orderly@db:5432/orderly

# Log every SQL statement (handy in dev, noisy in prod).
SQL_ECHO=false

# Comma-separated list of origins allowed to call the API.
# Dev = Vite dev server. Add your Netlify URL in production.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
